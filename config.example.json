{
  "workspace": "~/.pyclaw/workspace",
  
  "agents": {
    "defaults": {
      "model": "qwen3.5-plus",
      "provider": "bailian",
      "temperature": 0.7,
      "max_tokens": 4096,
      "max_iterations": 10,
      "system_prompt": "你是一个有帮助的 AI 助手，使用中文回复。"
    }
  },
  
  "providers": {
    "bailian": {
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key": "sk-sp-1449eadf40684bd087a87a8d2532eb1a"
    }
  },
  
  "memory": {
    "path": "~/.pyclaw/memory"
  },
  
  "sessions": {
    "isolation": "per-channel-peer"
  },
  
  "heartbeat": {
    "enable_email": false,
    "enable_calendar": false,
    "enable_weather": false,
    "default_interval_minutes": 30
  },
  
  "rag": {
    "enable_vector_search": true,
    "chunk_size": 500,
    "chunk_overlap": 50,
    "top_k": 5,
    "embedding_model": "BAAI/bge-small-zh-v1.5",
    "embedding_model_path": null,  // 本地模型路径（可选），如 "/home/user/models/bge-small-zh-v1.5"
    "vector_store": "memory",
    
    "retrieval_method": "hybrid",
    "hybrid_alpha": 0.5,
    "use_mmr": true,
    "mmr_lambda": 0.5,
    "use_rerank": false,
    "rerank_model": "BAAI/bge-reranker-base"
  },
  
  "multi_agent": {
    "_comment": "多 Agent 系统配置",
    "enabled_roles": "supervisor,researcher,coder,writer,analyst,executor",
    "_comment2": "或者只启用核心角色：enabled_roles: supervisor,researcher,writer,executor",
    
    "_comment3": "为每个 Agent 配置独立的大模型和参数",
    "agents": {
      "supervisor": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.7,
        "max_tokens": 4096,
        "max_iterations": 5
      },
      "researcher": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.5,
        "max_tokens": 4096
      },
      "coder": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.3,
        "max_tokens": 4096
      },
      "writer": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.8,
        "max_tokens": 4096
      },
      "analyst": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.5,
        "max_tokens": 4096
      },
      "executor": {
        "model": "qwen3.5-plus",
        "provider": "bailian",
        "temperature": 0.7,
        "max_tokens": 2048
      }
    }
  },
  
  "channels": {
    "feishu": {
      "enabled": false,
      "app_id": "",
      "app_secret": "",
      "verification_token": "",
      "encrypt_key": "",
      "host": "0.0.0.0",
      "port": 18791
    }
  },
  
  "server": {
    "host": "127.0.0.1",
    "port": 18790,
    "auth_token": ""
  }
}
