{
  "tools": [
    {
      "name": "send_email",
      "description": "发送邮件（支持附件、HTML、抄送）",
      "input_schema": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "description": "收件人邮箱地址，多个用逗号分隔"
          },
          "subject": {
            "type": "string",
            "description": "邮件主题"
          },
          "body": {
            "type": "string",
            "description": "邮件正文"
          },
          "html": {
            "type": "boolean",
            "description": "是否为 HTML 格式，默认 false",
            "default": false
          },
          "attachment": {
            "type": "string",
            "description": "附件文件路径，多个用逗号分隔"
          },
          "cc": {
            "type": "string",
            "description": "抄送邮箱地址，多个用逗号分隔"
          },
          "bcc": {
            "type": "string",
            "description": "密送邮箱地址，多个用逗号分隔"
          },
          "provider": {
            "type": "string",
            "description": "使用的邮箱服务商（qq/gmail/163/company），默认使用配置的",
            "enum": ["qq", "gmail", "163", "company"]
          }
        },
        "required": ["to", "subject", "body"]
      }
    },
    {
      "name": "configure_email",
      "description": "配置 SMTP 邮箱账户",
      "input_schema": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "邮箱服务商",
            "enum": ["qq", "gmail", "163", "company"]
          },
          "email": {
            "type": "string",
            "description": "邮箱地址"
          },
          "password": {
            "type": "string",
            "description": "授权码或密码"
          },
          "smtp_server": {
            "type": "string",
            "description": "SMTP 服务器地址（可选，自动匹配）"
          },
          "smtp_port": {
            "type": "integer",
            "description": "SMTP 端口（可选，自动匹配）"
          },
          "use_tls": {
            "type": "boolean",
            "description": "是否使用 TLS，默认 true",
            "default": true
          }
        },
        "required": ["provider", "email", "password"]
      }
    },
    {
      "name": "test_email",
      "description": "测试邮件发送，验证配置是否正确",
      "input_schema": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "description": "收件人邮箱（可选，默认发送到配置的邮箱）"
          }
        }
      }
    },
    {
      "name": "list_email_accounts",
      "description": "列出已配置的邮箱账户",
      "input_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "delete_email_account",
      "description": "删除已配置的邮箱账户",
      "input_schema": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "邮箱服务商",
            "enum": ["qq", "gmail", "163", "company"]
          }
        },
        "required": ["provider"]
      }
    }
  ]
}
