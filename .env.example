# PyClaw 环境变量配置
# ===================
# 复制此文件为 .env 并填写你的 API Key

# 阿里云百炼（通义千问）- 推荐
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# OpenAI（可选）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic（可选）
# 获取地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# 飞书渠道配置（可选）
# 获取地址：https://open.feishu.cn/
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=your-verification-token

# Gateway 配置
PYCLAW_GATEWAY_PORT=18789
PYCLAW_GATEWAY_HOST=0.0.0.0

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
PYCLAW_LOG_LEVEL=INFO
