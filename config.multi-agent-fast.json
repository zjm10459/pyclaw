{
  "workspace": "~/.pyclaw/workspace",
  
  "agents": {
    "defaults": {
      "model": "qwen-plus",
      "provider": "bailian",
      "temperature": 0.7,
      "max_tokens": 2048,
      "max_iterations": 5,
      "request_timeout": 120,
      "system_prompt": "你是一个有帮助的 AI 助手，使用中文回复。"
    }
  },
  
  "providers": {
    "bailian": {
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key": "xxx"
    }
  },
  
  "memory": {
    "path": "~/.pyclaw/memory"
  },
  
  "sessions": {
    "isolation": "per-channel-peer"
  },
  
  "heartbeat": {
    "enable_email": false,
    "enable_calendar": false,
    "enable_weather": false,
    "default_interval_minutes": 30
  },
  
  "multi_agent": {
    "_comment": "多 Agent 系统配置 - 快速版（解决超时问题）",
    "enabled_roles": "supervisor,writer,executor",
    "_comment_roles": "只启用 3 个核心角色，减少总执行时间",
    
    "agents": {
      "supervisor": {
        "model": "qwen-plus",
        "provider": "bailian",
        "temperature": 0.7,
        "max_tokens": 2048,
        "max_iterations": 3,
        "_comment": "使用 qwen-plus 而不是 qwen-max，更快"
      },
      "writer": {
        "model": "qwen-plus",
        "provider": "bailian",
        "temperature": 0.8,
        "max_tokens": 2048,
        "max_iterations": 5,
        "_comment": "使用 qwen-plus，均衡性能和速度"
      },
      "executor": {
        "model": "qwen-turbo",
        "provider": "bailian",
        "temperature": 0.7,
        "max_tokens": 2048,
        "max_iterations": 5,
        "_comment": "使用 qwen-turbo，最快的模型"
      }
    }
  },
  
  "server": {
    "host": "127.0.0.1",
    "port": 18790,
    "auth_token": ""
  }
}
